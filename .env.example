# submission-triage configuration.
#
# Copy this file to .env and fill it in; the server loads .env at startup and
# never overrides variables already set in the environment. The defaults shown
# are the built-in values you get if a line is omitted.
#
# To get running you only need the IMAP and SMTP blocks. Everything else is
# optional and has a working default.

SERVICE_NAME=submission-triage

# ─── HTTP ──────────────────────────────────────────────────────────────────
# Local health endpoint only (GET /health). Not a public web UI.
HTTP_PORT=8080
HTTP_READ_TIMEOUT_SECONDS=15
HTTP_WRITE_TIMEOUT_SECONDS=30
HTTP_SHUTDOWN_TIMEOUT_SECONDS=10

# ─── Storage ───────────────────────────────────────────────────────────────
# SQLite database file. Created on first run. Back it up to keep submission
# history and the audit log.
DB_PATH=./data/submission-triage.db

# ─── Logging ───────────────────────────────────────────────────────────────
# LEVEL: debug | info | warn | error.  FORMAT: json | text.
# LOG_DIR blank = log to stdout only (recommended under systemd/journald).
LOG_LEVEL=info
LOG_FORMAT=json
LOG_DIR=./logs
LOG_MAX_AGE_DAYS=14
LOG_ROTATION_HOURS=24

# ─── IMAP — the inbox to watch (REQUIRED) ──────────────────────────────────
# The poller stays off until HOST, USERNAME, and PASSWORD are all set.
# Gmail: enable 2-Step Verification, then create a 16-character App Password at
# https://myaccount.google.com/apppasswords and paste it (no spaces) below.
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USERNAME=you@gmail.com
# Gmail App Password — treat as a secret; never commit your real .env.
IMAP_PASSWORD=
IMAP_MAILBOX=INBOX
# How often to check for new mail. Default 30s.
IMAP_POLL_INTERVAL_SECONDS=30
# Uncomment for a snappier demo (overrides the line above):
# IMAP_POLL_INTERVAL_SECONDS=10
# Messages larger than this (megabytes) are skipped and left unread.
IMAP_MAX_MESSAGE_MB=32

# ─── SMTP — where replies are sent from (REQUIRED) ─────────────────────────
# For Gmail this is the same mailbox and the same App Password as IMAP above.
# Port 587 uses STARTTLS; port 465 uses implicit TLS. A server offering
# neither is refused.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=you@gmail.com
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=you@gmail.com
# Display name shown on replies. Default: Submission Triage.
SMTP_FROM_NAME=

# Reply channel: smtp | log. Blank = auto (smtp if configured, else a startup
# error). "log" prints replies instead of sending them — useful for a dry run.
OUTBOUND_PROVIDER=

# ─── LLM — Anthropic (OPTIONAL) ────────────────────────────────────────────
# Used only to (a) classify attachments the filename/keyword heuristics can't
# resolve and (b) read declared checklist fields. Without a key the heuristic
# classifier runs and field rules soft-pass on document presence.
# Get a key at https://console.anthropic.com/. Cost is pennies per submission
# on Haiku 4.5.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
ANTHROPIC_TIMEOUT_SECONDS=30
ANTHROPIC_MAX_TOKENS=2048

# ─── Checklists ────────────────────────────────────────────────────────────
# Directory of per-policy-type requirement files (one YAML each). Edit or add
# files, then restart.
CHECKLISTS_DIR=./checklists

# ─── Escalation timers (OPTIONAL) ──────────────────────────────────────────
# How often the escalation worker runs.
ESCALATION_INTERVAL_MINUTES=15
# Quiet hours on an open case before it escalates.
ESCALATION_THRESHOLD_HOURS=72
# Auto-close completed cases after this many quiet hours (336 = 14 days).
ESCALATION_AUTO_CLOSE_AFTER_HOURS=336
# How often the escalation digest email is sent.
ESCALATION_DIGEST_INTERVAL_HOURS=24
# Who receives escalation digests. Blank disables the global digest.
ESCALATION_DIGEST_RECIPIENT=

# ─── Reply worker pool (OPTIONAL) ──────────────────────────────────────────
REPLY_WORKERS=4
REPLY_QUEUE_SIZE=64

# ─── Retries for outbound calls (OPTIONAL) ─────────────────────────────────
RETRY_ATTEMPTS=3
RETRY_BASE_DELAY_MS=500

# ─── Telemetry — OpenTelemetry (OPTIONAL) ──────────────────────────────────
# Leave the endpoint blank to disable metrics export (the default). Set it to
# an OTLP collector URL to turn metrics on.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
