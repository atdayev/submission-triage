# Copy to .env and fill in. Loaded at startup; never overrides existing env vars.
# Only the IMAP and SMTP blocks are required; everything else has a default.

SERVICE_NAME=submission-triage

# ─── HTTP ──────────────────────────────────────────────────────────────────
# Local /health endpoint only, not a public UI.
HTTP_PORT=8080
HTTP_READ_TIMEOUT_SECONDS=15
HTTP_WRITE_TIMEOUT_SECONDS=30
HTTP_SHUTDOWN_TIMEOUT_SECONDS=10

# ─── Storage ───────────────────────────────────────────────────────────────
# SQLite file, created on first run; back it up.
DB_PATH=./data/submission-triage.db

# ─── Logging ───────────────────────────────────────────────────────────────
# LEVEL: debug|info|warn|error.  FORMAT: json|text.
LOG_LEVEL=info
LOG_FORMAT=json
# blank = stdout only (recommended under systemd); set a dir for rotating files
# LOG_DIR=
# 0 is not "keep forever" — falls back to a 7-day default
LOG_MAX_AGE_DAYS=14
LOG_ROTATION_HOURS=24

# ─── IMAP — inbox to watch (REQUIRED) ──────────────────────────────────────
# Off until HOST, USERNAME, and PASSWORD are set. Gmail: enable 2-Step
# Verification, create a 16-char App Password at
# https://myaccount.google.com/apppasswords (no spaces).
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USERNAME=you@gmail.com
# secret — never commit your real .env
IMAP_PASSWORD=
IMAP_MAILBOX=INBOX
IMAP_POLL_INTERVAL_SECONDS=30
# snappier demo (overrides above): IMAP_POLL_INTERVAL_SECONDS=10
# over-cap messages are skipped (logged once, then marked read)
IMAP_MAX_MESSAGE_MB=32
# label applied to a conversation once its submission is complete; blank disables
IMAP_COMPLETE_LABEL=Ready for Underwriting

# ─── SMTP — where replies are sent from (REQUIRED) ─────────────────────────
# Same mailbox/App Password as IMAP on Gmail. 587=STARTTLS, 465=implicit TLS.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=you@gmail.com
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=you@gmail.com
# default: Submission Triage
SMTP_FROM_NAME=

# Reply channel: smtp | log | blank (auto). "log" prints instead of sending.
OUTBOUND_PROVIDER=

# ─── LLM — Anthropic (OPTIONAL) ────────────────────────────────────────────
# Classifies ambiguous attachments and reads checklist fields. Without a key,
# heuristics classify and field rules soft-pass on presence. Pennies/submission.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
ANTHROPIC_TIMEOUT_SECONDS=30
ANTHROPIC_MAX_TOKENS=2048

# ─── Checklists ────────────────────────────────────────────────────────────
# One YAML per policy type; edit or add, then restart.
CHECKLISTS_DIR=./checklists

# ─── Escalation timers (OPTIONAL) ──────────────────────────────────────────
ESCALATION_INTERVAL_MINUTES=15
# quiet hours before an open case escalates
ESCALATION_THRESHOLD_HOURS=72
# auto-close completed cases after this many quiet hours (336 = 14 days)
ESCALATION_AUTO_CLOSE_AFTER_HOURS=336
ESCALATION_DIGEST_INTERVAL_HOURS=24
# blank disables the digest
ESCALATION_DIGEST_RECIPIENT=

# ─── Reply worker pool (OPTIONAL) ──────────────────────────────────────────
REPLY_WORKERS=4
REPLY_QUEUE_SIZE=64

# ─── Retries for outbound calls (OPTIONAL) ─────────────────────────────────
RETRY_ATTEMPTS=3
RETRY_BASE_DELAY_MS=500
