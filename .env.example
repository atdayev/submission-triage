HTTP_PORT=8080
HTTP_READ_TIMEOUT_SECONDS=15
HTTP_WRITE_TIMEOUT_SECONDS=30
HTTP_SHUTDOWN_TIMEOUT_SECONDS=10

DB_PATH=./data/submission-triage.db

LOG_LEVEL=info
LOG_FORMAT=json
LOG_DIR=./logs
LOG_MAX_AGE_DAYS=14
LOG_ROTATION_HOURS=24

POSTMARK_SERVER_TOKEN=
POSTMARK_FROM_ADDRESS=submissions@example.com
POSTMARK_FROM_NAME=Submission Triage
POSTMARK_WEBHOOK_SECRET=
POSTMARK_WEBHOOK_SIGNATURE_SECRET=

# Inbound IMAP polling — the credential-free on-ramp. Set host/username/password
# (a Gmail App Password works) to start the poller. Leave host blank to disable.
IMAP_HOST=
IMAP_PORT=993
IMAP_USERNAME=
IMAP_PASSWORD=
IMAP_MAILBOX=INBOX
IMAP_POLL_INTERVAL_SECONDS=30
# Messages larger than this are skipped (left unread), not pulled into memory.
IMAP_MAX_MESSAGE_MB=32

# Outbound SMTP — replies sent from your own mailbox (same creds as IMAP for
# Gmail/365). Leave host blank to disable.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=
SMTP_FROM_NAME=

# Reply channel: postmark | smtp | log. Empty = auto (smtp if configured,
# else postmark if a token is set, else log-only).
OUTBOUND_PROVIDER=

# OpenTelemetry — leave unset to disable metric export entirely.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# Reply-send worker pool — bounded so a Postmark outage during a burst
# can't spawn unbounded goroutines.
REPLY_WORKERS=4
REPLY_QUEUE_SIZE=64

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
ANTHROPIC_TIMEOUT_SECONDS=30
ANTHROPIC_MAX_TOKENS=2048

CHECKLISTS_DIR=./checklists
ESCALATION_INTERVAL_MINUTES=15
ESCALATION_THRESHOLD_HOURS=72
ESCALATION_AUTO_CLOSE_AFTER_HOURS=336
ESCALATION_DIGEST_INTERVAL_HOURS=24
ESCALATION_DIGEST_RECIPIENT=

RETRY_ATTEMPTS=3
RETRY_BASE_DELAY_MS=500
