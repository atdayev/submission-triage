# Copy to .deploy.env (gitignored — never committed) and fill in your host.
# `make deploy` cross-compiles and ships using your own gcloud login; no keys in the repo.
DEPLOY_INSTANCE=your-gce-instance
DEPLOY_ZONE=us-central1-a
DEPLOY_USER=your-ssh-user
